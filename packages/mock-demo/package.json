{
  "name": "@field-iq/mock-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "In-memory LOTO session timeline that drives the standalone Vercel demos (dashboard + glasses-webapp). No backend required.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./photos": {
      "types": "./src/photos.ts",
      "import": "./src/photos.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
