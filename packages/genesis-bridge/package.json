{
  "name": "@field-iq/genesis-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reference-content bridge for Field IQ. Returns image/GIF/3D scene refs for any (procedureId, stepNumber, deviceKind). Mock provider today; Genesis API swap in Phase 2F+ is a one-line change.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./assets": "./assets/"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
