# EON Field IQ backend — Railway environment variables.
# Set these in Railway → Service → Variables. Never commit `.env.local`.

# --- Required ---
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB              # Neon connection string
REDIS_URL=redis://default:PASS@HOST.upstash.io:6379           # Upstash Redis URL
JWT_SIGNING_SECRET=                                            # Railway can auto-generate; openssl rand -hex 32 locally
REPORT_SIGNING_KEY=                                            # Railway can auto-generate; openssl rand -hex 32

# --- Optional / dev-friendly defaults ---
PORT=3000                                                      # Railway injects $PORT automatically
NODE_ENV=production
LOG_LEVEL=info
EMAIL_TRANSPORT=console                                        # `console` logs magic links; `resend` / `postmark` go live in 2C
EMAIL_API_KEY=                                                 # leave blank if EMAIL_TRANSPORT=console
USE_MOCK_VERIFIER=false                                        # the Python verifier (services/verifier) consumes the queue in prod

# --- Photo storage (S3 deferred to 2C; v1 stores data URIs in audit_log) ---
S3_ENDPOINT=                                                   # leave blank → in-database photo storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- One-shot migrations on first boot (Railway is browser-only) ---
RUN_MIGRATIONS_ON_BOOT=false                                   # set to `true` for the first deploy only, then flip back to false
SEED_ON_BOOT=false                                             # set to `true` for the first deploy only, then flip back
