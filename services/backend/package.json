{
  "name": "@field-iq/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EON Field IQ backend — Fastify REST + WebSocket, Drizzle/Postgres, Redis, S3.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src seed",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx seed/index.ts"
  },
  "dependencies": {
    "@field-iq/schema": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
