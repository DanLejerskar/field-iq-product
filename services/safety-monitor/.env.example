# EON Field IQ Python safety-monitor — Railway environment variables.

# --- Required for live mode (Claude Sonnet 4.6) ---
ANTHROPIC_API_KEY=sk-ant-...                        # https://console.anthropic.com/settings/keys
ANTHROPIC_MODEL=claude-sonnet-4-6
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB    # same Neon string as the backend
REDIS_URL=redis://default:PASS@HOST.upstash.io:6379 # same Upstash URL as the backend

# --- Mode toggle ---
MONITOR_MOCK=false                                  # true short-circuits Claude calls; keyword path still fires

# --- Tuning ---
BASE_INTERVAL_S=15                                  # default tick interval per session
ESCALATED_INTERVAL_S=5                              # interval when last severity was high/critical
INACTIVE_SESSION_TTL_S=300                          # drop sessions silent for > 5 min
