# EON Field IQ Python verifier — Railway environment variables.

# --- Required for live mode (Claude Sonnet 4.6) ---
ANTHROPIC_API_KEY=sk-ant-...                                   # https://console.anthropic.com/settings/keys
ANTHROPIC_MODEL=claude-sonnet-4-6
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB               # same Neon string as the backend
REDIS_URL=redis://default:PASS@HOST.upstash.io:6379            # same Upstash URL as the backend

# --- Mode toggle ---
VERIFIER_MOCK=false                                            # true returns canned verdicts (dev / no key)

# --- Photo storage (mirrors backend; v1 reads data URIs from audit_log) ---
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
