# cert-generator env vars. Copy to .env.local at the repo root.

# Required everywhere.
DATABASE_URL=postgresql://field_iq:field_iq_dev@localhost:5432/field_iq
REDIS_URL=redis://localhost:6379

# Storage selection: "local" writes to LOCAL_OUTPUT_DIR; "supabase" uploads to
# Supabase Storage. Default is "local" so dev works without credentials.
STORAGE_BACKEND=local
LOCAL_OUTPUT_DIR=./certs

# Supabase Storage (only required when STORAGE_BACKEND=supabase).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=certificates

# Public base URL embedded in the QR code + footer. Default suits prod; in dev
# we still issue real cert IDs and verifiable hashes.
VERIFY_BASE_URL=https://app.fieldiq.io
