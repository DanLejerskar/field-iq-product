{
  "name": "field-iq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EON Field IQ — LOTO v1. AI-verified industrial procedure execution on Meta Ray-Ban Display.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "migrate": "pnpm --filter @field-iq/backend migrate",
    "seed": "pnpm --filter @field-iq/backend seed",
    "test:e2e": "pnpm --filter @field-iq/e2e test",
    "test:e2e:phase2b": "pnpm --filter @field-iq/e2e exec playwright test phase_2b_real_backend",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
