# EON Field IQ — LOTO v1 · environment template.
# Copy to .env.local (via `pnpm setup`) and fill in. NEVER commit .env.local.
# Values here are redacted placeholders only.

# --- AI verification (verifier, Python) — required by M5 ---
ANTHROPIC_API_KEY=<your-key-here>
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database (backend) — required by M2 ---
# Local Docker Compose default shown; set a Neon URL to use managed Postgres.
DATABASE_URL=postgresql://field_iq:field_iq_dev@localhost:5432/field_iq

# --- Cache + queues (backend, verifier) — required by M3 ---
# Local Docker Compose default shown; set an Upstash URL to use managed Redis.
REDIS_URL=redis://localhost:6379

# --- Object storage (backend) — required by M3 ---
# Local MinIO defaults shown.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=field-iq
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=field_iq
S3_SECRET_ACCESS_KEY=field_iq_dev
S3_FORCE_PATH_STYLE=true

# --- Magic-link email (backend) — required by M3; console fallback in dev ---
EMAIL_API_KEY=<your-key-here>
EMAIL_FROM=no-reply@eonreality.com
EMAIL_TRANSPORT=console

# --- Signing secrets (auto-generated by `pnpm setup` if absent) ---
JWT_SIGNING_SECRET=<openssl-rand-hex-32>
REPORT_SIGNING_KEY=<openssl-rand-hex-32>

# --- Service hosts (clients use these to find the backend) ---
API_HOST=http://localhost:3000
WS_HOST=ws://localhost:3000
PORT=3000

# --- Meta Wearables (M7+) ---
META_WEARABLES_APP_ID=<your-app-id>

# --- Mobile code signing (M7) ---
APPLE_DEVELOPER_TEAM_ID=<your-team-id>
ANDROID_KEYSTORE_PATH=<path-to-keystore>
ANDROID_KEYSTORE_PASSWORD=<your-password>
ANDROID_KEY_ALIAS=<your-alias>
ANDROID_KEY_PASSWORD=<your-password>

# --- Dev toggles ---
USE_MOCK_VERIFIER=true
